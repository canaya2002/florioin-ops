# ============================================
# FLORIOIN OPS HUB — ENV VARS TEMPLATE
# ============================================
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it's in .gitignore.

# ============================================
# MODE — MOCK FIRST, REAL APIs LAST
# ============================================
NODE_ENV=development
USE_MOCK_DATA=true
# Per-integration override (empty = inherit USE_MOCK_DATA)
USE_MOCK_APOLLO=
USE_MOCK_GMAIL=
USE_MOCK_CALENDAR=
USE_MOCK_WHATSAPP=
USE_MOCK_STRIPE=
USE_MOCK_FLORIOIN_DB=
USE_MOCK_GA4=
USE_MOCK_GSC=
USE_MOCK_VERCEL=
USE_MOCK_INSTAGRAM=
USE_MOCK_TIKTOK=

# ============================================
# SUPABASE (same FlorioIn instance, schema 'ops')
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://heqzwommoufzqoprybyq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# ANTHROPIC (Claude Sonnet 4.5 + Haiku 4.5)
# ============================================
ANTHROPIC_API_KEY=

# ============================================
# APOLLO.io
# ============================================
APOLLO_API_KEY=

# ============================================
# GOOGLE APIs (Gmail + Calendar + GA4 + GSC)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=
GSC_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY_URL=https://www.florioin.app

# ============================================
# META (WhatsApp Business + Instagram)
# ============================================
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ============================================
# TIKTOK FOR BUSINESS
# ============================================
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ============================================
# VERCEL API
# ============================================
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# ============================================
# STRIPE (LIVE account: acct_1TTQyTCuIL8omOZD)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_OPS=

# ============================================
# RESEND (transactional emails)
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=carlos@florioin.app
RESEND_FROM_NAME=Carlos Anaya

# ============================================
# INNGEST (background jobs)
# ============================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=false

# ============================================
# SLACK (optional notifications)
# ============================================
SLACK_WEBHOOK_URL=
SLACK_QUIET_HOURS_START=22
SLACK_QUIET_HOURS_END=8

# ============================================
# SENTRY (error tracking)
# ============================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=florioin-ops

# ============================================
# AUTH (founder allowlist)
# ============================================
NEXT_PUBLIC_FOUNDER_EMAIL=carlos@florioin.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ============================================
# BACKUPS
# ============================================
BACKUP_RETENTION_DAYS=30
BACKUP_WEEKLY_RETENTION_WEEKS=12
BACKUP_STORAGE_BUCKET=ops-backups

# ============================================
# AI BEHAVIOR
# ============================================
AI_CONFIDENCE_THRESHOLD=0.7
AI_MAX_DAILY_EMAILS=200
AI_RESEARCH_CACHE_DAYS=7
